programa {
  funcao inicio() {
    real laranjas_inicial, laranjas_final, total


    escreva("Quantidade de laranjas inicial: ")
    leia(laranjas_inicial)

    escreva("Quantidade de laranjas final: ")
    leia(laranjas_final)

    total = laranjas_inicial - laranjas_final
    escreva("Foram vendidas no dia: " + total + " Laranjas ")






















    
  }
}
